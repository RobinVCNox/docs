{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Nox Energy API Documentation",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "guides/introduction",
              "guides/get-started"
            ]
          },
          {
            "group": "Integration",
            "pages": [
              "guides/energy-supplier-integration"
            ]
          },
          {
            "group": "Package Guides",
            "pages": [
              "guides/full-control-package"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "guides/partner-webhooks"
            ]
          }
        ]
      },
      {
        "tab": "API Docs",
        "groups": [
          {
            "group": "API setup",
            "pages": [
              "api-docs/authentication"
            ]
          },
          {
            "group": "Full NOX Control Package",
            "openapi": {
              "source": "api-docs/full-control/openapi-full-control.json",
              "directory": "api-docs/full-control"
            }
          },
          {
            "group": "Supplier Control Package", 
            "openapi": {
              "source": "api-docs/supplier-control/openapi-thermal-control.json",
              "directory": "api-docs/supplier-control"
            }
          },
          {
            "group": "Manufacturer Package",
            "openapi": {
              "source": "api-docs/manufacturer/openapi-manufacturer.json",
              "directory": "api-docs/manufacturer"
            }
          },
          {
            "group": "Connecting Users and Devices",
            "pages": [
              {
                "group": "By supplier",
                "openapi": {
                  "source": "api-docs/supplier-integration/openapi-supplier-auth-v2.json",
                  "directory": "api-docs/supplier-integration"
                },
                "pages": [
                  "POST /supplier/link-sessions",
                  {
                    "group": "Deprecated",
                    "openapi": {
                      "source": "api-docs/supplier-integration/openapi-supplier-auth.json",
                      "directory": "api-docs/supplier-integration-deprecated"
                    },
                    "pages": [
                      "POST /users/{userId}/link"
                    ]
                  }
                ]
              },
              {
                "group": "By manufacturer",
                "openapi": {
                  "source": "api-docs/manufacturer-integration/openapi-manufacturer-auth-v2.json",
                  "directory": "api-docs/manufacturer-integration"
                },
                "pages": [
                  "POST /manufacturer/link-sessions",
                  "POST /manufacturer/device-connections",
                  {
                    "group": "Deprecated",
                    "openapi": {
                      "source": "api-docs/manufacturer-integration/openapi-manufacturer-auth.json",
                      "directory": "api-docs/manufacturer-integration-deprecated"
                    },
                    "pages": [
                      "POST /manufacturers/nox",
                      "POST /manufacturers/suppliers"
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Supported Assets",
        "groups": [
          {
            "group": "Supported Assets",
            "pages": [
              "supported-assets/supported-assets-overview"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog/product-updates"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://www.nox.energy/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/no_background_1280w.svg",
    "dark": "/logo/no_background_1280w.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@nox.energy"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard Demo",
      "href": "https://nox-supplier.vercel.app/"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/energy-nox"
    }
  }
}