{
  "openapi": "3.1.0",
  "info": {
    "title": "NOX Energy API - Manufacturer",
    "description": "# Manufacturer API Documentation\n\nThis documentation shows only the endpoints available to manufacturer users.\n\n## Authentication\n\n1. Get your API key from [NOX Energy](mailto:support@nox.energy).\n2. Include the API key in your API calls with the header: `x-api-key: YOUR_API_KEY`.\n\n## Access Level\n\nThis documentation is specifically for **manufacturer users** who have access to these endpoints.\n\nBase URL: [https://api.nox.energy](https://api.nox.energy)\n",
    "version": "1.0.0"
  },
  "paths": {
    "/v1/manufacturer/settings": {
      "post": {
        "tags": [
          "Manufacturer Control"
        ],
        "summary": "Submit Manufacturer Settings",
        "description": "Update on a user/device level the manufacturer settings.\n\n You can change the following settings:\n\n * The lower and upper comfort temperature bounds for domestic hot water heating in degrees celcius.\n\n * The optimization settings.\n\n * The country code and the postal code",
        "operationId": "submit_manufacturer_settings_v1_manufacturer_settings_post",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "title": "Request Body"
              },
              "examples": {
                "settings_example": {
                  "summary": "Example of optimization settings submission",
                  "value": {
                    "device_id": "123",
                    "dhw": {
                      "temperature_upper_bound": 50,
                      "temperature_lower_bound": 40
                    },
                    "optimization_settings": {
                      "pv_self_consumption": true,
                      "dynamic_tariff": true,
                      "flex_trading": false
                    },
                    "location": {
                      "country": "BE",
                      "postal_code": "123456"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Submit Manufacturer Settings V1 Manufacturer Settings Post"
                },
                "example": {
                  "status": "success",
                  "message": "Settings updated successfully.",
                  "meta": {
                    "manufacturer": "Manufacturer A"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/manufacturer/devices": {
      "get": {
        "tags": [
          "Asset Info"
        ],
        "summary": "Get Manufacturer Devices",
        "description": "Get information about all NOX connected devices\n associated with your manufacturer account.",
        "operationId": "get_manufacturer_devices_v1_manufacturer_devices_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 4000,
              "minimum": 1,
              "description": "\nThe maximum number of items to return per page of results.\n\nThis should be used together with the `next_token` parameter to paginate through results.\n\nRead the pagination parameter documentation for more details.\n",
              "default": 1000,
              "title": "Limit"
            },
            "description": "\nThe maximum number of items to return per page of results.\n\nThis should be used together with the `next_token` parameter to paginate through results.\n\nRead the pagination parameter documentation for more details.\n"
          },
          {
            "name": "next_token",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "\nThe `next_token` is a token used to retrieve the next page of results when there are more results\nthan can fit in a single page(=API response).\n\nBy default, the API will return a `next_token` of the first page if no token was given as a parameter.\n\nIf the token is `null` you have reached the end of the results.\n\nThis should be used together with the `limit` parameter to paginate through results.\n\n\n\nTo get all results of your call, you can keep calling the same API call with the previously returned `next_token` until it returns `null`.\n",
              "title": "Next Token"
            },
            "description": "\nThe `next_token` is a token used to retrieve the next page of results when there are more results\nthan can fit in a single page(=API response).\n\nBy default, the API will return a `next_token` of the first page if no token was given as a parameter.\n\nIf the token is `null` you have reached the end of the results.\n\nThis should be used together with the `limit` parameter to paginate through results.\n\n\n\nTo get all results of your call, you can keep calling the same API call with the previously returned `next_token` until it returns `null`.\n"
          },
          {
            "name": "device_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "\nThe ID of the device to filter on. If not provided, all devices are returned.\n",
              "title": "Device Id"
            },
            "description": "\nThe ID of the device to filter on. If not provided, all devices are returned.\n"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response for thermal-control API",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Get Manufacturer Devices V1 Manufacturer Devices Get"
                },
                "example": {
                  "data": [
                    {
                      "country": "BE",
                      "device_id": "device_id_123",
                      "energy_supplier": "Energy Supplier A",
                      "auth_origin": "nox",
                      "dhw": {
                        "temperature_upper_bound": 50,
                        "temperature_lower_bound": 40
                      },
                      "optimization_settings": {
                        "pv_self_consumption": true,
                        "dynamic_tariff": true,
                        "flex_trading": false
                      }
                    },
                    {
                      "country": "BE",
                      "device_id": "device_id_456",
                      "energy_supplier": "Energy Supplier B",
                      "auth_origin": "supplier",
                      "dhw": {
                        "temperature_upper_bound": 55,
                        "temperature_lower_bound": 45
                      },
                      "optimization_settings": {
                        "pv_self_consumption": false,
                        "dynamic_tariff": false,
                        "flex_trading": true
                      }
                    }
                  ],
                  "meta": {
                    "manufacturer": "Manufacturer A",
                    "next_token": "123556777"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
